# Optional — leave this file uncopied and the app runs on the shared Langsys
# demo project: a READ-ONLY key with a fixed, pre-translated catalog. Existing
# phrases translate; anything you add or edit won't (read-only keys can't
# register tokens).
#
# To watch discovery register + translate YOUR phrases: copy to `.env` and use
# your own project id with a WRITE key — in a LOCAL clone only. Don't paste a
# write key into a StackBlitz sandbox (forks are shareable). Read-only keys are
# safe anywhere, including public browser apps.
VITE_LANGSYS_PROJECT_ID=your-project-id-here
VITE_LANGSYS_API_KEY=your-api-key-here

# Optional: point the SDK at a non-production instance for local development
# (e.g. a Laragon nova instance). Leave unset in production — it defaults to
# https://api.langsys.dev/api.
# VITE_LANGSYS_API_URL=http://langsys-nova.test/api
